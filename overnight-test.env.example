# Copy to overnight-test.env before starting an overnight run.
# This file is intentionally conservative so we can leave the stack running
# without burning through quota at the default local cadence.

APP_ENV_FILE=overnight-test.env

POSTGRES_USER=traffic
POSTGRES_PASSWORD=traffic
POSTGRES_DB=traffic
PGHOST_PORT=5432
HOST_BIND_ADDRESS=127.0.0.1

TOMTOM_API_KEY=replace-with-your-tomtom-key

TRAFFIC_MODE=tile
TRAFFIC_POLL_SECONDS=120
TRAFFIC_STARTUP_VALIDATION_ENABLED=true
TRAFFIC_TILE_ZOOM=10
TRAFFIC_TILE_CONCURRENCY=2
TRAFFIC_TILE_ROUTE_BUFFER_METERS=500
TRAFFIC_TILE_QUOTA_TARGET_DAILY_REQUESTS=20000
TRAFFIC_TILE_QUOTA_ADAPTIVE_CAP_DAILY_REQUESTS=24000
TRAFFIC_TILE_QUOTA_HARD_STOP_DAILY_REQUESTS=26000

TRAFFIC_RETENTION_ENABLED=true
TRAFFIC_RETENTION_DAYS=30
TRAFFIC_OBS_INGEST_GAP_MINUTES=20
TRAFFIC_OBS_QUOTA_WARN_PERCENT=80
TRAFFIC_OBS_QUOTA_CRITICAL_PERCENT=95
TRAFFIC_OBS_PROVIDER_NULL_CYCLE_THRESHOLD=3
TRAFFIC_TIMESERIES_ENABLED=true
TRAFFIC_TIMESERIES_CREATE_HYPERTABLES=true
TRAFFIC_TIMESERIES_ENABLE_COMPRESSION=true
TRAFFIC_TIMESERIES_CREATE_CONTINUOUS_AGGREGATES=true
TRAFFIC_TIMESERIES_COMPRESSION_AFTER_DAYS=7

API_SECURITY_ENABLED=true
API_SECURITY_KEYS=dev-local-key
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS_PER_MINUTE=120
API_RATE_LIMIT_TRUST_FORWARDED_FOR=false
DASHBOARD_PUBLIC_DATA_ENABLED=true
SPRING_PROFILES_ACTIVE=

OVERNIGHT_CORRIDOR=I25
OVERNIGHT_MONITOR_SECONDS=300
OVERNIGHT_STARTUP_TIMEOUT_SECONDS=300
